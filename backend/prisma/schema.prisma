generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(VIEWER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN    // Full access: manage users, all CRUD
  MANAGER  // Can edit allocations, people, projects, absences
  VIEWER   // Read-only access to timeline and reports
}

// ─── Teams ───────────────────────────────────────────────────────────────────

model Team {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?  // hex color for UI
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  people    Person[]
}

// ─── Roles (flexible/custom) ─────────────────────────────────────────────────

model Role {
  id        String   @id @default(uuid())
  name      String   @unique  // e.g. "Developer", "Project Manager", "Designer"
  shortName String?           // e.g. "DEV", "PM", "DES"
  color     String?           // hex color for UI
  createdAt DateTime @default(now())
  people    Person[]
}

// ─── People ──────────────────────────────────────────────────────────────────

model Person {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String
  email           String?  @unique
  roleId          String
  role            Role     @relation(fields: [roleId], references: [id])
  teamId          String?
  team            Team?    @relation(fields: [teamId], references: [id])
  
  // Working hours (supports part-time)
  hoursMonday     Float    @default(8.0)
  hoursTuesday    Float    @default(8.0)
  hoursWednesday  Float    @default(8.0)
  hoursThursday   Float    @default(8.0)
  hoursFriday     Float    @default(6.5)
  
  // Jira/Tempo integration
  jiraAccountId   String?  // Jira account ID (for Tempo API matching)
  jiraEmail       String?  // Jira email (fallback matching)
  
  startDate       DateTime?  // when they joined
  endDate         DateTime?  // if they left
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  allocations     Allocation[]
  absences        Absence[]
  weeklySchedules WeeklySchedule[]
}

// ─── Weekly Schedule Overrides (per-week working hours) ──────────────────────
// When present, overrides the Person's default hoursMonday..hoursFriday for the
// week starting on `weekStart` (always a Monday). Lets people work different
// days/hours week to week. A day set to 0 means "not working that day".

model WeeklySchedule {
  id             String   @id @default(uuid())
  personId       String
  person         Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  weekStart      DateTime // Monday of the target week (date only, UTC midnight)

  hoursMonday    Float    @default(0)
  hoursTuesday   Float    @default(0)
  hoursWednesday Float    @default(0)
  hoursThursday  Float    @default(0)
  hoursFriday    Float    @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([personId, weekStart])
  @@index([personId, weekStart])
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique  // short code e.g. "PROJ-001"
  color       String?  // hex color for UI
  logo        String?  // filename of uploaded logo
  description String?
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean  @default(true)
  
  // Jira/Tempo integration
  jiraProjectKey  String?  // e.g. "NKD", "APOLLO" — maps to Jira project

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  allocations Allocation[]
  codes       ProjectCode[]  // additional codes beyond the primary `code`
}

// ─── Project Codes (additional codes for one project) ────────────────────────
// A project keeps its primary `Project.code`; this holds extra codes so one
// project can be identified by several keys (e.g. PNEU + PSD for Pneuhage).
// All codes (primary + these) are used for Tempo/Jira worklog matching.

model ProjectCode {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code      String   @unique
  createdAt DateTime @default(now())

  @@index([projectId])
}

// ─── Allocations (person ↔ project, percentage-based) ────────────────────────

model Allocation {
  id         String   @id @default(uuid())
  personId   String
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Percentage of available time allocated to this project
  percentage Float    // 0-100, can exceed 100 if overallocated across projects
  
  // Date range for this allocation
  startDate  DateTime
  endDate    DateTime
  
  notes      String?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([personId, startDate, endDate])
  @@index([projectId, startDate, endDate])
}

// ─── Absence Types (custom) ─────────────────────────────────────────────────

model AbsenceType {
  id        String   @id @default(uuid())
  name      String   @unique  // e.g. "Holiday", "Sick Leave", "Travelling"
  color     String?  // hex color for UI
  icon      String?  // icon identifier
  isPaid    Boolean  @default(true)
  createdAt DateTime @default(now())
  absences  Absence[]
}

// ─── Absences ────────────────────────────────────────────────────────────────

model Absence {
  id            String      @id @default(uuid())
  personId      String
  person        Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  absenceTypeId String
  absenceType   AbsenceType @relation(fields: [absenceTypeId], references: [id])
  
  startDate     DateTime
  endDate       DateTime
  isHalfDay     Boolean  @default(false)  // half-day absence
  notes         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([personId, startDate, endDate])
}

// ─── Public Holidays ─────────────────────────────────────────────────────────

model PublicHoliday {
  id        String   @id @default(uuid())
  name      String
  date      DateTime @unique
  isHalfDay Boolean  @default(false)
  
  createdAt DateTime @default(now())
}

// ─── Tempo Integration ───────────────────────────────────────────────────────

model TempoConfig {
  id            String   @id @default(uuid())
  baseUrl       String   @default("https://api.tempo.io/4")  // Tempo Cloud API
  apiToken      String   // Tempo API token (encrypted at rest ideally)
  jiraBaseUrl   String?  // e.g. "https://yourcompany.atlassian.net"
  jiraEmail     String?  // Jira user email (for Jira REST API auth)
  jiraApiToken  String?  // Jira API token (for Jira REST API auth)
  isActive      Boolean  @default(true)
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Cached worklogs fetched from Tempo
model TempoWorklog {
  id              String   @id @default(uuid())
  tempoWorklogId  Int      @unique  // Tempo's own worklog ID
  jiraAccountId   String   // Jira user account ID
  jiraDisplayName String?  // Author display name from Tempo (for debugging)
  jiraIssueId     String?  // Jira issue ID (numeric, from Tempo API)
  jiraProjectKey  String   // Jira project key
  jiraIssueKey    String   // e.g. "NKD-1234"
  description     String?
  date            DateTime
  timeSpentHours  Float    // hours logged
  
  // Resolved links to team-planner entities (nullable if not matched)
  personId        String?
  projectId       String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([jiraAccountId, date])
  @@index([jiraProjectKey, date])
  @@index([personId, date])
  @@index([projectId, date])
}

// Cached Jira entity lookups (users and issues) to avoid repeated API calls
model JiraCache {
  key       String   @id        // e.g. "user:abc123" or "issue:998667"
  type      String               // "user" or "issue"
  data      String               // JSON blob
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}
