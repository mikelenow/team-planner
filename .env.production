# Team Planner - Production Environment
# Copy this to .env on the production server and fill in real values.

# Database
POSTGRES_DB=utilization_planner
POSTGRES_USER=planner
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING

# Port that nginx listens on (cloudflared routes to this)
HOST_PORT=8087
